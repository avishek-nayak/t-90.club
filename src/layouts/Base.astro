---
import '../styles/global.css';
const { title = 't90.club — Calculators for endurance athletes', description = 'A focused calculator suite for endurance athletes. No accounts, no devices, no tracking — just math.' } = Astro.props;
const path = Astro.url.pathname;
const isActive = (p) => path === p || (p !== '/' && path.startsWith(p));
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="logo" aria-label="t90.club home">
          <span class="logo-mark">t90</span>
          <span class="logo-dot">·</span>
          <span class="logo-tld">club</span>
        </a>
        <nav class="nav" aria-label="Primary">
          <a href="/calculators" class={isActive('/calculators') ? 'active' : ''}>Calculators</a>
          <a href="/articles" class={isActive('/articles') ? 'active' : ''}>Articles</a>
          <a href="/about" class={isActive('/about') ? 'active' : ''}>About</a>
          <a href="/creator" class={isActive('/creator') ? 'active' : ''}>Creator</a>
        </nav>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container footer-inner">
        <div class="footer-brand">
          <div class="logo">
            <span class="logo-mark">t90</span><span class="logo-dot">·</span><span class="logo-tld">club</span>
          </div>
          <p class="muted">Calculators for endurance athletes.<br/>No accounts. No devices. No tracking.</p>
        </div>
        <div class="footer-cols">
          <div>
            <div class="eyebrow">Tools</div>
            <a href="/calculators">All calculators</a>
            <a href="/calculators#metabolic">Metabolic</a>
            <a href="/calculators#training">Training zones</a>
            <a href="/calculators#race">Race planning</a>
          </div>
          <div>
            <div class="eyebrow">Read</div>
            <a href="/articles">Articles</a>
            <a href="/about">About t90.club</a>
            <a href="/creator">Meet the creator</a>
          </div>
        </div>
      </div>
      <div class="container footer-bottom">
        <span class="mono muted">© {new Date().getFullYear()} t90.club</span>
        <span class="mono muted">v0.1 · build {new Date().toISOString().slice(0,10)}</span>
      </div>
    </footer>

    <style>
      .site-header {
        position: sticky; top: 0; z-index: 10;
        background: color-mix(in oklab, var(--canvas) 86%, transparent);
        backdrop-filter: saturate(140%) blur(10px);
        -webkit-backdrop-filter: saturate(140%) blur(10px);
        border-bottom: 1px solid var(--line);
      }
      .header-inner {
        display: flex; align-items: center; justify-content: space-between;
        height: 64px;
      }
      .logo { display: inline-flex; align-items: baseline; gap: 2px; font-weight: 700; letter-spacing: -0.02em; font-size: 1.05rem; }
      .logo-mark { color: var(--ink); }
      .logo-dot { color: var(--accent); font-weight: 700; }
      .logo-tld { color: var(--muted); font-weight: 500; }
      .nav { display: flex; gap: var(--s-5); }
      .nav a { font-size: 0.92rem; color: var(--muted); }
      .nav a:hover, .nav a.active { color: var(--ink); }
      .btn-cta { padding: 8px 14px; font-size: 0.88rem; }

      @media (max-width: 720px) {
        .nav { display: none; }
        .btn-cta { padding: 7px 12px; font-size: 0.82rem; }
      }

      .site-footer {
        margin-top: var(--s-10);
        border-top: 1px solid var(--line);
        background: var(--canvas-2);
      }
      .footer-inner {
        display: grid; grid-template-columns: 1.2fr 2fr;
        gap: var(--s-7);
        padding: var(--s-8) var(--s-5) var(--s-6);
      }
      .footer-cols { display: grid; grid-template-columns: 1fr 1fr; gap: var(--s-5); }
      .footer-cols a { display: block; color: var(--ink-2); font-size: 0.92rem; padding: 4px 0; }
      .footer-cols .eyebrow { margin-bottom: var(--s-3); }
      .footer-bottom {
        display: flex; justify-content: space-between;
        padding: var(--s-4) var(--s-5);
        border-top: 1px solid var(--line);
      }
      @media (max-width: 720px) {
        .footer-inner { grid-template-columns: 1fr; }
        .footer-cols { grid-template-columns: 1fr 1fr; }
      }
    </style>
  </body>
</html>
