---
import Base from '../../layouts/Base.astro';
---
<Base title="Race time predictor — t90.club" description="Predict race times across distances using the Riegel formula.">
  <section class="calc-page-head">
    <div class="container-narrow">
      <a href="/calculators" class="calc-back">← All calculators</a>
      <div class="eyebrow">Running performance</div>
      <h1>Race time predictor</h1>
      <p class="calc-lede">Enter one known race time. See predicted times across every common distance, using the Riegel formula.</p>
    </div>
  </section>

  <section class="section-tight">
    <div class="container-narrow">
      <div class="calc-card">
        <div class="calc-form">
          <div class="row cols-2">
            <label class="field">
              <span class="field-row">Known distance</span>
              <select id="dist">
                <option value="1.609">1 mile</option>
                <option value="3">3 km</option>
                <option value="5" selected>5 km</option>
                <option value="10">10 km</option>
                <option value="15">15 km</option>
                <option value="21.0975">Half marathon</option>
                <option value="42.195">Marathon</option>
              </select>
            </label>
            <label class="field">
              <span class="field-row">Known time <em>mm:ss or h:mm:ss</em></span>
              <input id="time" type="text" inputmode="numeric" placeholder="22:30" value="22:30"/>
            </label>
          </div>
        </div>

        <div class="result-block">
          <div class="zones predict">
            <div class="z header">
              <span class="z-name">Distance</span>
              <span class="z-desc">Predicted time</span>
              <span class="z-val">Pace</span>
            </div>
            <div class="z" data-row="5"><span class="z-name">5 km</span><span class="z-desc" data-cell="time">—</span><span class="z-val" data-cell="pace">—</span></div>
            <div class="z" data-row="10"><span class="z-name">10 km</span><span class="z-desc" data-cell="time">—</span><span class="z-val" data-cell="pace">—</span></div>
            <div class="z" data-row="15"><span class="z-name">15 km</span><span class="z-desc" data-cell="time">—</span><span class="z-val" data-cell="pace">—</span></div>
            <div class="z" data-row="21.0975"><span class="z-name">Half marathon</span><span class="z-desc" data-cell="time">—</span><span class="z-val" data-cell="pace">—</span></div>
            <div class="z" data-row="42.195"><span class="z-name">Marathon</span><span class="z-desc" data-cell="time">—</span><span class="z-val" data-cell="pace">—</span></div>
          </div>

          <div class="chart-wrap">
            <div class="chart-title mono">Predicted time across distance</div>
            <svg id="chart" viewBox="0 0 700 240" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg"></svg>
          </div>
        </div>
      </div>

      <details class="notes">
        <summary>Formula & limits</summary>
        <p><strong>Riegel (1981):</strong></p>
        <pre>T₂ = T₁ × (D₂ / D₁) ^ 1.06</pre>
        <p>Predicts time T₂ over distance D₂ from a known time T₁ over D₁. The 1.06 exponent accounts for the non-linear fatigue cost of going longer.</p>
        <p class="muted">Most accurate within ~3× of the known distance. Predicting marathon from a 5K is a stretch; predicting 10K from a 5K is solid. Marathon-specific endurance (long-run base, fueling, race tactics) isn't captured — Riegel assumes adequate preparation for the target distance.</p>
      </details>
    </div>
  </section>
</Base>

<script>
  const $ = (s) => document.querySelector(s);
  const distEl=$('#dist'), timeEl=$('#time'), chart=$('#chart');

  function parseTime(str) {
    if (!str) return null;
    const parts = str.split(':').map(s => +s.trim());
    if (parts.some(isNaN)) return null;
    if (parts.length === 3) return parts[0]*3600 + parts[1]*60 + parts[2];
    if (parts.length === 2) return parts[0]*60 + parts[1];
    if (parts.length === 1) return parts[0]*60;
    return null;
  }
  function fmtTime(s) {
    if (!s || s<0) return '—';
    const h=Math.floor(s/3600), m=Math.floor((s%3600)/60), sec=Math.round(s%60);
    if (h>0) return `${h}:${String(m).padStart(2,'0')}:${String(sec).padStart(2,'0')}`;
    return `${m}:${String(sec).padStart(2,'0')}`;
  }
  function fmtPace(secPerKm) {
    if (!secPerKm) return '—';
    const m=Math.floor(secPerKm/60), s=Math.round(secPerKm%60);
    return `${m}:${String(s).padStart(2,'0')}/km`;
  }
  function riegel(t1, d1, d2) { return t1 * Math.pow(d2/d1, 1.06); }

  const targetDistances = [5, 10, 15, 21.0975, 42.195];

  function calc() {
    const t1 = parseTime(timeEl.value);
    const d1 = +distEl.value;
    if (!t1 || !d1) return;

    document.querySelectorAll('.predict .z[data-row]').forEach((row) => {
      const d2 = +row.dataset.row;
      const t2 = riegel(t1, d1, d2);
      row.querySelector('[data-cell="time"]').textContent = fmtTime(t2);
      row.querySelector('[data-cell="pace"]').textContent = fmtPace(t2/d2);
      if (Math.abs(d2 - d1) < 0.05) row.classList.add('is-input'); else row.classList.remove('is-input');
    });

    drawChart(t1, d1);
  }

  function drawChart(t1, d1) {
    const W=700, H=240, padL=58, padR=20, padT=20, padB=40;
    const plotW = W - padL - padR, plotH = H - padT - padB;

    const dMin=1, dMax=50;
    const steps=60;
    const pts=[];
    const times=[];
    for (let i=0; i<=steps; i++) {
      const d = dMin + (dMax-dMin)*(i/steps);
      const t = riegel(t1, d1, d);
      pts.push({d, t});
      times.push(t);
    }
    const tMax = Math.max(...times);
    const yMax = Math.ceil(tMax/600)*600;
    const yMin = 0;

    const xScale = (d) => padL + ((d-dMin)/(dMax-dMin)) * plotW;
    const yScale = (t) => padT + plotH - ((t-yMin)/(yMax-yMin)) * plotH;

    const xTicks = [5, 10, 15, 21.0975, 42.195].map((d) => {
      const x = xScale(d);
      const label = d===21.0975 ? 'HM' : d===42.195 ? 'M' : `${d}K`;
      return `
        <line x1="${x}" x2="${x}" y1="${padT}" y2="${padT+plotH}" stroke="rgba(255,255,255,0.05)"/>
        <text x="${x}" y="${padT+plotH+18}" fill="rgba(255,255,255,0.6)" font-family="JetBrains Mono, monospace" font-size="10" text-anchor="middle">${label}</text>
      `;
    }).join('');

    const yStep = yMax / 4;
    const yTicks = [];
    for (let i=0; i<=4; i++) {
      const t = yStep*i;
      const y = yScale(t);
      yTicks.push(`
        <line x1="${padL}" x2="${padL+plotW}" y1="${y}" y2="${y}" stroke="rgba(255,255,255,0.05)"/>
        <text x="${padL-8}" y="${y+3}" fill="rgba(255,255,255,0.55)" font-family="JetBrains Mono, monospace" font-size="10" text-anchor="end">${fmtTime(t)}</text>
      `);
    }

    const path = pts.map((p,i) => `${i===0?'M':'L'} ${xScale(p.d).toFixed(1)},${yScale(p.t).toFixed(1)}`).join(' ');

    const markers = targetDistances.map((d) => {
      const t = riegel(t1, d1, d);
      const x = xScale(d), y = yScale(t);
      return `
        <circle cx="${x}" cy="${y}" r="4" fill="var(--accent)"/>
        <text x="${x}" y="${y-12}" fill="rgba(255,255,255,0.85)" font-family="JetBrains Mono, monospace" font-size="10" text-anchor="middle">${fmtTime(t)}</text>
      `;
    }).join('');

    const inputX = xScale(d1), inputY = yScale(t1);
    const inputMarker = `
      <circle cx="${inputX}" cy="${inputY}" r="7" fill="none" stroke="#fff" stroke-width="2"/>
      <circle cx="${inputX}" cy="${inputY}" r="4" fill="#fff"/>
    `;

    chart.innerHTML = `
      ${yTicks.join('')}
      ${xTicks}
      <path d="${path}" fill="none" stroke="var(--accent)" stroke-width="2"/>
      ${markers}
      ${inputMarker}
    `;
  }

  [distEl, timeEl].forEach((el) => el.addEventListener('input', calc));
  distEl.addEventListener('change', calc);
  calc();
</script>

<style>
  .zones.predict { background: rgba(255,255,255,0.02); margin-bottom: var(--s-5); }
  .zones.predict .z { grid-template-columns: 1.2fr 1fr 1fr; }
  .zones.predict .z.header { background: rgba(255,255,255,0.04); }
  .zones.predict .z.header .z-name,
  .zones.predict .z.header .z-desc,
  .zones.predict .z.header .z-val {
    font-family: var(--font-mono); font-size: 0.7rem;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: rgba(255,255,255,0.55); font-weight: 400;
  }
  .zones.predict .z.is-input {
    background: color-mix(in oklab, var(--accent) 12%, transparent);
    border-left: 3px solid var(--accent);
  }
  .zones.predict .z-desc {
    color: #fff;
    font-family: var(--font-display); font-weight: 600; font-size: 1.05rem;
  }

  .result-block { background: var(--ink); color: #fff; padding: var(--s-6) 0 var(--s-6); }
  .result-block > *:not(.zones) { padding-left: var(--s-6); padding-right: var(--s-6); }
  .result-block .zones { margin-left: 0; margin-right: 0; }

  .chart-wrap { background: rgba(255,255,255,0.03); border-radius: var(--radius); padding: var(--s-3) var(--s-4); margin: 0 var(--s-6); }
  .chart-title { color: rgba(255,255,255,0.55); margin-bottom: var(--s-2); letter-spacing: 0.1em; text-transform: uppercase; font-size: 0.7rem; }
  .chart-wrap svg { display: block; width: 100%; height: auto; }
</style>
