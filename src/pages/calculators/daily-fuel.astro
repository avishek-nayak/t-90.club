---
import Base from '../../layouts/Base.astro';
---
<Base title="Daily fuel needs — t90.club" description="Calories you actually need on training days for endurance athletes.">
  <section class="calc-page-head">
    <div class="container-narrow">
      <a href="/calculators" class="calc-back">← All calculators</a>
      <div class="eyebrow">Fueling & nutrition</div>
      <h1>Daily fuel needs</h1>
      <p class="calc-lede">Calories you actually need today, factoring in BMR, lifestyle activity, and the energy cost of the training you did (or are about to do).</p>
    </div>
  </section>

  <section class="section-tight">
    <div class="container-narrow">
      <div class="calc-card">
        <div class="calc-form">
          <!-- Body inputs -->
          <div class="seg-group" role="radiogroup" aria-label="Sex">
            <label class="seg active"><input type="radio" name="sex" value="male" checked/><span>Male</span></label>
            <label class="seg"><input type="radio" name="sex" value="female"/><span>Female</span></label>
          </div>

          <div class="row cols-3">
            <label class="field"><span class="field-row">Age <em>yr</em></span><input id="age" type="number" min="14" max="90" value="30"/></label>
            <label class="field"><span class="field-row">Weight <em>kg</em></span><input id="weight" type="number" step="0.1" min="35" value="70"/></label>
            <label class="field"><span class="field-row">Height <em>cm</em></span><input id="height" type="number" step="0.1" min="120" value="175"/></label>
          </div>

          <!-- Lifestyle activity (outside training) -->
          <div style="margin-top: var(--s-6);">
            <span class="field-label">Lifestyle activity (outside of training)</span>
            <div class="row cols-4 lifestyle">
              <label class="opt"><input type="radio" name="life" value="1.2"/><span><strong>Sedentary</strong><em>Desk job</em></span></label>
              <label class="opt active"><input type="radio" name="life" value="1.375" checked/><span><strong>Light</strong><em>Walks, errands</em></span></label>
              <label class="opt"><input type="radio" name="life" value="1.55"/><span><strong>Active</strong><em>On feet a lot</em></span></label>
              <label class="opt"><input type="radio" name="life" value="1.725"/><span><strong>Very active</strong><em>Manual labour</em></span></label>
            </div>
          </div>

          <!-- Training today -->
          <div style="margin-top: var(--s-6);">
            <span class="field-label">Today's training</span>
            <div class="row cols-3">
              <label class="field">
                <span class="field-row">Type</span>
                <select id="sport">
                  <option value="rest">Rest day</option>
                  <option value="run-easy">Run · easy</option>
                  <option value="run-tempo" selected>Run · tempo/threshold</option>
                  <option value="run-interval">Run · intervals</option>
                  <option value="cycle-easy">Cycle · easy (Z1–Z2)</option>
                  <option value="cycle-tempo">Cycle · tempo (Z3)</option>
                  <option value="cycle-hard">Cycle · threshold+ (Z4–Z5)</option>
                </select>
              </label>
              <label class="field"><span class="field-row">Duration <em>min</em></span><input id="dur" type="number" min="0" value="60"/></label>
              <label class="field">
                <span class="field-row">Goal</span>
                <select id="goal">
                  <option value="maintain" selected>Maintain weight</option>
                  <option value="cut">Lean down (−15%)</option>
                  <option value="build">Build (+10%)</option>
                </select>
              </label>
            </div>
          </div>
        </div>

        <!-- Result + chart -->
        <div class="result-block">
          <div class="result-headline">
            <div class="result-num"><span id="total">—</span><span class="unit">kcal/day</span></div>
            <div class="result-lbl">Total daily target</div>
          </div>

          <!-- Stacked bar showing the breakdown -->
          <div class="chart-wrap">
            <svg id="chart" viewBox="0 0 700 120" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg"></svg>
            <div class="legend">
              <span><i style="background:#444"></i> BMR <b id="leg-bmr">—</b></span>
              <span><i style="background:#888"></i> Lifestyle <b id="leg-life">—</b></span>
              <span><i style="background:var(--accent)"></i> Training <b id="leg-train">—</b></span>
              <span class="legend-goal"><i style="background:#fff;border:1px dashed #fff"></i> Goal adj. <b id="leg-goal">—</b></span>
            </div>
          </div>

          <!-- Macro split -->
          <div class="macro-row">
            <div class="macro">
              <div class="macro-num"><span id="m-carb">—</span><span class="macro-u">g</span></div>
              <div class="macro-lbl mono">Carbs <span id="m-carb-k" class="muted"></span></div>
            </div>
            <div class="macro">
              <div class="macro-num"><span id="m-prot">—</span><span class="macro-u">g</span></div>
              <div class="macro-lbl mono">Protein <span id="m-prot-k" class="muted"></span></div>
            </div>
            <div class="macro">
              <div class="macro-num"><span id="m-fat">—</span><span class="macro-u">g</span></div>
              <div class="macro-lbl mono">Fat <span id="m-fat-k" class="muted"></span></div>
            </div>
          </div>
        </div>
      </div>

      <details class="notes">
        <summary>Formula & limits</summary>
        <p><strong>BMR</strong> — Mifflin–St Jeor (1990):</p>
        <pre>Male:   10·W + 6.25·H − 5·A + 5
Female: 10·W + 6.25·H − 5·A − 161</pre>
        <p><strong>NEAT × lifestyle factor</strong> — multiplier applied to BMR for non-training daily movement.</p>
        <p><strong>Training kcal</strong> — MET-based estimate × weight × hours.</p>
        <pre>run easy ~9 MET · run tempo ~11 · run intervals ~13
cycle easy ~6 MET · tempo ~8 · threshold+ ~11</pre>
        <p><strong>Macro split</strong> — endurance default: 55% carbs / 20% protein / 25% fat. Carbs at 4 kcal/g, protein 4, fat 9.</p>
        <p class="muted">Estimates only. Individual variance is ±10–15% — use these as a starting point, then adjust based on weight trend and energy in training.</p>
      </details>
    </div>
  </section>
</Base>

<script>
  // ====== DOM refs ======
  const $ = (s) => document.querySelector(s);
  const ageEl=$('#age'), wEl=$('#weight'), hEl=$('#height');
  const durEl=$('#dur'), sportEl=$('#sport'), goalEl=$('#goal');
  const totalEl=$('#total'), chart=$('#chart');
  const lBmr=$('#leg-bmr'), lLife=$('#leg-life'), lTrain=$('#leg-train'), lGoal=$('#leg-goal');
  const mC=$('#m-carb'), mP=$('#m-prot'), mF=$('#m-fat');
  const mCk=$('#m-carb-k'), mPk=$('#m-prot-k'), mFk=$('#m-fat-k');

  // MET values per sport bucket
  const MET = {
    'rest': 0, 'run-easy': 9, 'run-tempo': 11, 'run-interval': 13,
    'cycle-easy': 6, 'cycle-tempo': 8, 'cycle-hard': 11,
  };

  function getRadio(name) { return document.querySelector(`input[name="${name}"]:checked`).value; }

  function calc() {
    const age=+ageEl.value, w=+wEl.value, h=+hEl.value, dur=+durEl.value;
    if (!age||!w||!h) { totalEl.textContent='—'; return; }

    // BMR
    const base = 10*w + 6.25*h - 5*age;
    const bmr = getRadio('sex')==='male' ? base+5 : base-161;

    // Lifestyle (NEAT layer above BMR)
    const lifeMult = +getRadio('life');
    const neat = bmr * (lifeMult - 1); // the *extra* on top of BMR

    // Training kcal: MET × kg × hours
    const met = MET[sportEl.value] || 0;
    const train = met * w * (dur/60);

    // Goal adjustment (applied to the sum)
    const subtotal = bmr + neat + train;
    const goal = goalEl.value;
    let adj = 0;
    if (goal === 'cut') adj = -subtotal * 0.15;
    if (goal === 'build') adj = subtotal * 0.10;

    const total = Math.round(subtotal + adj);

    totalEl.textContent = total.toLocaleString();
    lBmr.textContent  = Math.round(bmr).toLocaleString();
    lLife.textContent = Math.round(neat).toLocaleString();
    lTrain.textContent = Math.round(train).toLocaleString();
    lGoal.textContent = (adj>=0?'+':'') + Math.round(adj).toLocaleString();

    drawChart(bmr, neat, train, adj);

    // Macros — endurance default split on the TOTAL
    const carbsKcal = total * 0.55;
    const protKcal  = total * 0.20;
    const fatKcal   = total * 0.25;
    mC.textContent = Math.round(carbsKcal/4).toLocaleString();
    mP.textContent = Math.round(protKcal/4).toLocaleString();
    mF.textContent = Math.round(fatKcal/9).toLocaleString();
    mCk.textContent = `· ${Math.round(carbsKcal).toLocaleString()} kcal`;
    mPk.textContent = `· ${Math.round(protKcal).toLocaleString()} kcal`;
    mFk.textContent = `· ${Math.round(fatKcal).toLocaleString()} kcal`;
  }

  function drawChart(bmr, neat, train, adj) {
    const w = 700, h = 120, padX = 16, padY = 18, barH = 56, barY = 32;
    const usableW = w - padX*2;
    const total = bmr + neat + train + Math.abs(adj);
    if (total <= 0) { chart.innerHTML = ''; return; }

    // Scale: total fills the bar
    const xBmr   = (bmr / total) * usableW;
    const xLife  = (neat / total) * usableW;
    const xTrain = (train / total) * usableW;
    const xAdj   = (Math.abs(adj) / total) * usableW;

    let x = padX;
    const seg = (xw, color, dash) => {
      if (xw <= 0) return '';
      const r = `<rect x="${x}" y="${barY}" width="${xw}" height="${barH}" fill="${color}" ${dash?'stroke="#fff" stroke-dasharray="4 3"':''} />`;
      x += xw;
      return r;
    };

    let segs = '';
    segs += seg(xBmr, '#444');
    segs += seg(xLife, '#888');
    segs += seg(xTrain, 'var(--accent)');
    if (adj !== 0) segs += seg(xAdj, adj > 0 ? 'rgba(255,255,255,0.18)' : 'rgba(255,255,255,0.18)', true);

    // axis ticks
    const ticks = [0, 0.25, 0.5, 0.75, 1].map((p) => {
      const tx = padX + p * usableW;
      const kcal = Math.round(total * p);
      return `<line x1="${tx}" x2="${tx}" y1="${barY+barH}" y2="${barY+barH+6}" stroke="rgba(255,255,255,0.3)"/>
              <text x="${tx}" y="${barY+barH+20}" fill="rgba(255,255,255,0.6)" font-family="JetBrains Mono, monospace" font-size="10" text-anchor="middle">${kcal.toLocaleString()}</text>`;
    }).join('');

    chart.innerHTML = `
      <rect x="${padX}" y="${barY}" width="${usableW}" height="${barH}" fill="rgba(255,255,255,0.04)"/>
      ${segs}
      ${ticks}
    `;
  }

  // ====== events ======
  document.querySelectorAll('.seg-group, .lifestyle').forEach((group) => {
    group.addEventListener('change', () => {
      group.querySelectorAll('.seg, .opt').forEach((s) => s.classList.remove('active'));
      group.querySelector('input:checked').closest('.seg, .opt').classList.add('active');
      calc();
    });
  });
  [ageEl, wEl, hEl, durEl].forEach((el) => el.addEventListener('input', calc));
  [sportEl, goalEl].forEach((el) => el.addEventListener('change', calc));
  calc();
</script>

<style>
  /* Lifestyle pill grid */
  .lifestyle { gap: var(--s-2) !important; }
  .opt { position: relative; cursor: pointer; }
  .opt input { position: absolute; opacity: 0; inset: 0; cursor: pointer; }
  .opt span {
    display: flex; flex-direction: column; gap: 2px;
    padding: var(--s-3);
    border: 1px solid var(--line); border-radius: var(--radius);
    background: var(--canvas); transition: all 150ms ease;
    min-height: 64px;
  }
  .opt span strong { font-size: 0.9rem; font-weight: 600; font-family: var(--font-display); color: var(--ink); }
  .opt span em { font-style: normal; font-size: 0.74rem; color: var(--muted); }
  .opt.active span { background: var(--ink); border-color: var(--ink); }
  .opt.active span strong, .opt.active span em { color: #fff; }
  .opt.active span em { color: var(--muted-2); }

  /* Result block */
  .result-block {
    background: var(--ink); color: #fff;
    padding: var(--s-6);
  }
  .result-headline {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: var(--s-4); flex-wrap: wrap; margin-bottom: var(--s-5);
  }
  .result-headline .unit {
    font-size: 0.9rem; font-family: var(--font-mono);
    color: var(--muted-2); margin-left: var(--s-3);
  }

  /* Chart */
  .chart-wrap {
    background: rgba(255,255,255,0.03);
    border-radius: var(--radius);
    padding: var(--s-3);
    margin-bottom: var(--s-5);
  }
  .chart-wrap svg { display: block; width: 100%; height: auto; }
  .legend {
    display: flex; flex-wrap: wrap; gap: var(--s-4);
    margin-top: var(--s-3);
    font-family: var(--font-mono); font-size: 0.72rem;
    color: rgba(255,255,255,0.65);
  }
  .legend span { display: inline-flex; align-items: center; gap: 6px; }
  .legend i { width: 10px; height: 10px; border-radius: 2px; display: inline-block; }
  .legend b { color: #fff; font-weight: 600; font-family: var(--font-mono); }

  /* Macro split */
  .macro-row {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: var(--s-3);
    padding-top: var(--s-5);
    border-top: 1px solid rgba(255,255,255,0.08);
  }
  .macro-num { font-family: var(--font-display); font-weight: 600; font-size: 1.8rem; letter-spacing: -0.02em; line-height: 1; }
  .macro-num .macro-u { font-size: 0.8rem; font-family: var(--font-mono); color: var(--muted-2); margin-left: 4px; }
  .macro-lbl { color: rgba(255,255,255,0.55); margin-top: 6px; letter-spacing: 0.1em; text-transform: uppercase; font-size: 0.7rem; }
  .macro-lbl .muted { color: rgba(255,255,255,0.4); }
</style>
