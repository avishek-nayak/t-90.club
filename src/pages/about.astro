<style>
  .page-head { padding: var(--s-9) 0 var(--s-7); border-bottom: 1px solid var(--line); }
  .lede { font-size: 1.1rem; max-width: 580px; margin-top: var(--s-4); }

  .prose-long h2 { margin-top: var(--s-7); margin-bottom: var(--s-3); }
  .prose-long h2:first-child { margin-top: 0; }
  .prose-long p, .prose-long li { font-size: 1.02rem; color: var(--ink-2); }
  .prose-long ol { padding-left: 1.2rem; }
  .prose-long ol li { margin-bottom: var(--s-3); }
  .placeholder {
    background: var(--accent-soft);
    color: #8a3a17;
    padding: 2px 6px; border-radius: 3px;
    font-style: italic;
  }
</style>
