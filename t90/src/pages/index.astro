---
import Base from '../layouts/Base.astro';
import { totalCount } from '../lib/catalog.js';
---
<Base>
  <section class="hero">
    <div class="grid-bg hero-bg" aria-hidden="true"></div>
    <div class="container hero-inner">
      <h1 class="rise rise-2">
        Endurance training,<br/>reduced to <span class="accent-underline">math.</span>
      </h1>
      <p class="lede rise rise-3">
        A focused suite of <strong>{totalCount}+ calculators</strong> for runners, cyclists, triathletes, and swimmers.
        No accounts. No wearables. No data harvesting. Open a calculator, get an answer, close the tab.
      </p>
      <div class="hero-cta rise rise-4">
        <a href="/calculators" class="btn">Open the calculators →</a>
      </div>
    </div>
  </section>
</Base>

<style>
  .hero { position: relative; padding: var(--s-10) 0; overflow: hidden; }
  .hero-bg { position: absolute; inset: 0; opacity: 0.55; pointer-events: none; }
  .hero-inner { position: relative; max-width: 900px; }
  .hero h1 .accent-underline {
    background: linear-gradient(transparent 64%, var(--accent-soft) 64%);
    padding: 0 4px;
  }
  .lede { font-size: 1.2rem; color: var(--ink-2); max-width: 640px; margin-top: var(--s-5); }
  .hero-cta { margin-top: var(--s-7); }
  @media (max-width: 720px) {
    .hero { padding: var(--s-8) 0; }
  }
</style>
