---
import Base from '../../layouts/Base.astro';
---
<Base title="During-workout carbs — t90.club" description="Carbohydrate fueling target during runs and rides, g/hr.">
  <section class="calc-page-head">
    <div class="container-narrow">
      <a href="/calculators" class="calc-back">← All calculators</a>
      <div class="eyebrow">Fueling & nutrition</div>
      <h1>During-workout carbs</h1>
      <p class="calc-lede">Grams of carbohydrate per hour to fuel a run or ride — scaled by duration and intensity. Higher rates require multiple-transportable carbs (glucose + fructose).</p>
    </div>
  </section>

  <section class="section-tight">
    <div class="container-narrow">
      <div class="calc-card">
        <div class="calc-form">
          <div class="row cols-3">
            <label class="field"><span class="field-row">Duration <em>hr</em></span><input id="dur" type="number" step="0.25" min="0.25" max="12" value="3"/></label>
            <label class="field">
              <span class="field-row">Intensity</span>
              <select id="intensity">
                <option value="easy">Easy (Z1–Z2)</option>
                <option value="mod" selected>Moderate (Z3)</option>
                <option value="hard">Hard (Z4+ / race)</option>
              </select>
            </label>
            <label class="field">
              <span class="field-row">Sport</span>
              <select id="sport">
                <option value="run">Run</option>
                <option value="cycle" selected>Cycle</option>
              </select>
            </label>
          </div>

          <div style="margin-top: var(--s-5);">
            <label class="field">
              <span class="field-row">Gut training level <em><span id="gut-label">Standard</span></em></span>
              <input id="gut" type="range" min="0" max="2" step="1" value="1"/>
            </label>
            <div class="range-marks">
              <span>Beginner</span><span>Standard</span><span>Trained gut</span>
            </div>
          </div>
        </div>

        <div class="result-block">
          <div class="result-headline">
            <div class="result-num"><span id="ghr">—</span><span class="unit">g carbs / hr</span></div>
            <div class="result-lbl">Target intake rate</div>
          </div>

          <div class="callouts">
            <div class="callout">
              <div class="callout-num"><span id="total-g">—</span><span class="callout-u">g</span></div>
              <div class="callout-lbl mono">Total carbs over session</div>
            </div>
            <div class="callout">
              <div class="callout-num"><span id="total-k">—</span><span class="callout-u">kcal</span></div>
              <div class="callout-lbl mono">Total energy from carbs</div>
            </div>
            <div class="callout">
              <div class="callout-num"><span id="strat">—</span></div>
              <div class="callout-lbl mono">Carb source strategy</div>
            </div>
          </div>

          <!-- Hour-by-hour cumulative chart -->
          <div class="chart-wrap">
            <div class="chart-title mono">Cumulative carbs over duration</div>
            <svg id="chart" viewBox="0 0 700 220" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg"></svg>
          </div>
        </div>
      </div>

      <details class="notes">
        <summary>Formula & limits</summary>
        <p>Sports-nutrition consensus on carbohydrate oxidation rates during exercise:</p>
        <pre>&lt; 60 min       no carbs required (mouth rinse optional)
60–150 min     30–60 g/hr (glucose alone)
150–180 min    60–75 g/hr (glucose + fructose, ~2:1)
&gt; 180 min      75–90 g/hr (multiple transportable)
Race / trained 90–120 g/hr (advanced gut training)</pre>
        <p>Intensity adjusts within the band — harder efforts can absorb more carbs (but also tolerate less). Gut training shifts the realistic upper limit. Running tolerates fewer g/hr than cycling on average (jostling, smaller stomach window).</p>
        <p class="muted">Practise race-day fueling in training. The "trained gut" upper end requires weeks of progressive practice and the right carb form (gels, drinks, chews mixed).</p>
      </details>
    </div>
  </section>
</Base>

<script>
  const $ = (s) => document.querySelector(s);
  const durEl=$('#dur'), intEl=$('#intensity'), sportEl=$('#sport'), gutEl=$('#gut');
  const gutLabel=$('#gut-label');
  const ghrEl=$('#ghr'), totalG=$('#total-g'), totalK=$('#total-k'), stratEl=$('#strat');
  const chart=$('#chart');

  function recommend(dur, intensity, sport, gut) {
    let g;
    // base by duration
    if (dur < 1) g = 0;
    else if (dur < 2.5) g = 45;       // 30–60 band
    else if (dur < 3) g = 68;          // 60–75 band
    else g = 82;                        // 75–90 band

    // intensity tweaks within band
    if (intensity === 'easy') g *= 0.85;
    if (intensity === 'hard') g *= 1.15;

    // running absorbs ~10% less than cycling on average
    if (sport === 'run') g *= 0.9;

    // gut training scalar — 0 beginner, 1 standard, 2 trained
    if (gut === 0) g *= 0.80;
    if (gut === 2) g *= 1.30;

    // cap and floor
    if (dur < 1) return 0;
    return Math.min(120, Math.max(20, Math.round(g/5)*5));
  }

  function strategy(g) {
    if (g === 0) return 'None';
    if (g <= 60) return 'Glucose / maltodextrin';
    if (g <= 75) return 'Glucose + fructose ~2:1';
    return 'Multi-transportable, mixed sources';
  }

  function calc() {
    const dur=+durEl.value, gut=+gutEl.value;
    const intensity=intEl.value, sport=sportEl.value;
    if (!dur || dur <= 0) { ghrEl.textContent='—'; return; }

    const g = recommend(dur, intensity, sport, gut);
    const totalGr = Math.round(g * dur);
    const totalKc = Math.round(totalGr * 4);

    ghrEl.textContent = g === 0 ? '0' : g.toString();
    totalG.textContent = totalGr.toLocaleString();
    totalK.textContent = totalKc.toLocaleString();
    stratEl.textContent = strategy(g);
    gutLabel.textContent = ['Beginner','Standard','Trained gut'][gut];

    drawChart(dur, g);
  }

  function drawChart(dur, gPerHr) {
    const W=700, H=220, padL=44, padR=16, padT=16, padB=36;
    const plotW = W - padL - padR;
    const plotH = H - padT - padB;

    const totalG = gPerHr * dur;
    const yMax = Math.max(30, Math.ceil((totalG + 10)/30)*30);
    const xMax = Math.max(1, Math.ceil(dur));

    // Build cumulative curve points
    const steps = Math.max(20, Math.round(dur * 12));
    const pts = [];
    for (let i = 0; i <= steps; i++) {
      const t = (i/steps) * dur;
      const cum = t * gPerHr;
      const x = padL + (t/xMax) * plotW;
      const y = padT + plotH - (cum/yMax) * plotH;
      pts.push(`${x.toFixed(1)},${y.toFixed(1)}`);
    }

    // hour markers
    const hourMarks = [];
    for (let hr = 0; hr <= xMax; hr++) {
      const x = padL + (hr/xMax) * plotW;
      const cum = Math.min(hr, dur) * gPerHr;
      const y = padT + plotH - (cum/yMax) * plotH;
      hourMarks.push(`
        <line x1="${x}" x2="${x}" y1="${padT}" y2="${padT+plotH}" stroke="rgba(255,255,255,0.06)"/>
        <text x="${x}" y="${padT+plotH+18}" fill="rgba(255,255,255,0.55)" font-family="JetBrains Mono, monospace" font-size="10" text-anchor="middle">${hr}h</text>
        ${hr > 0 && hr <= dur ? `<circle cx="${x}" cy="${y}" r="3.5" fill="var(--accent)"/>
          <text x="${x}" y="${y-10}" fill="rgba(255,255,255,0.85)" font-family="JetBrains Mono, monospace" font-size="10" text-anchor="middle">${Math.round(cum)}g</text>` : ''}
      `);
    }

    // y axis ticks
    const yTicks = [];
    for (let i = 0; i <= 4; i++) {
      const v = (yMax/4) * i;
      const y = padT + plotH - (v/yMax) * plotH;
      yTicks.push(`
        <line x1="${padL}" x2="${padL+plotW}" y1="${y}" y2="${y}" stroke="rgba(255,255,255,0.05)"/>
        <text x="${padL-8}" y="${y+3}" fill="rgba(255,255,255,0.55)" font-family="JetBrains Mono, monospace" font-size="10" text-anchor="end">${Math.round(v)}g</text>
      `);
    }

    // area fill below the curve
    const areaPath = `M ${padL},${padT+plotH} L ${pts.join(' L ')} L ${padL + plotW},${padT+plotH} Z`;
    const linePath = `M ${pts.join(' L ')}`;

    chart.innerHTML = `
      ${yTicks.join('')}
      ${hourMarks.join('')}
      <path d="${areaPath}" fill="var(--accent)" fill-opacity="0.12"/>
      <path d="${linePath}" fill="none" stroke="var(--accent)" stroke-width="2"/>
    `;
  }

  [durEl, gutEl].forEach((el) => el.addEventListener('input', calc));
  [intEl, sportEl].forEach((el) => el.addEventListener('change', calc));
  calc();
</script>

<style>
  .range-marks {
    display: flex; justify-content: space-between;
    margin-top: 6px;
    font-family: var(--font-mono); font-size: 0.7rem; color: var(--muted);
  }

  .result-block { background: var(--ink); color: #fff; padding: var(--s-6); }
  .result-headline {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: var(--s-4); flex-wrap: wrap; margin-bottom: var(--s-5);
  }
  .result-headline .unit {
    font-size: 0.9rem; font-family: var(--font-mono); color: var(--muted-2); margin-left: var(--s-3);
  }

  .callouts {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: var(--s-3); margin-bottom: var(--s-5);
    padding-bottom: var(--s-5); border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  @media (max-width: 560px) { .callouts { grid-template-columns: 1fr; } }
  .callout-num { font-family: var(--font-display); font-weight: 600; font-size: 1.6rem; letter-spacing: -0.02em; line-height: 1; }
  .callout-u { font-size: 0.78rem; font-family: var(--font-mono); color: var(--muted-2); margin-left: 4px; }
  .callout-lbl { color: rgba(255,255,255,0.55); margin-top: 6px; letter-spacing: 0.1em; text-transform: uppercase; font-size: 0.7rem; }

  .chart-wrap { background: rgba(255,255,255,0.03); border-radius: var(--radius); padding: var(--s-3) var(--s-4) var(--s-2); }
  .chart-title { color: rgba(255,255,255,0.55); margin-bottom: var(--s-2); letter-spacing: 0.1em; text-transform: uppercase; font-size: 0.7rem; }
  .chart-wrap svg { display: block; width: 100%; height: auto; }

  input[type="range"] {
    -webkit-appearance: none; appearance: none;
    width: 100%; height: 6px; background: var(--line); border-radius: 999px;
    outline: none;
  }
  input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none; appearance: none;
    width: 18px; height: 18px; border-radius: 50%;
    background: var(--ink); cursor: pointer; border: 2px solid #fff;
    box-shadow: 0 0 0 1px var(--ink);
  }
  input[type="range"]::-moz-range-thumb {
    width: 18px; height: 18px; border-radius: 50%;
    background: var(--ink); cursor: pointer; border: 2px solid #fff;
    box-shadow: 0 0 0 1px var(--ink);
  }
</style>
