---
import Base from '../../layouts/Base.astro';
---
<Base title="W/kg power-to-weight — t90.club" description="Cycling power-to-weight ratio and climbing category from FTP and weight.">
  <section class="calc-page-head">
    <div class="container-narrow">
      <a href="/calculators" class="calc-back">← All calculators</a>
      <div class="eyebrow">Cycling performance</div>
      <h1>W/kg power-to-weight</h1>
      <p class="calc-lede">The number that matters on every climb. Drop your FTP and weight in — see your power-to-weight ratio and the rider category it lines up with.</p>
    </div>
  </section>

  <section class="section-tight">
    <div class="container-narrow">
      <div class="calc-card">
        <div class="calc-form">
          <div class="seg-group" role="radiogroup" aria-label="Sex (for category bands)">
            <label class="seg active"><input type="radio" name="sex" value="male" checked/><span>Male</span></label>
            <label class="seg"><input type="radio" name="sex" value="female"/><span>Female</span></label>
          </div>

          <div class="row cols-2">
            <label class="field"><span class="field-row">FTP <em>watts</em></span><input id="ftp" type="number" min="50" max="600" step="1" value="250"/></label>
            <label class="field"><span class="field-row">Weight <em>kg</em></span><input id="weight" type="number" step="0.1" min="35" value="70"/></label>
          </div>
        </div>

        <div class="result-block">
          <div class="result-headline">
            <div class="result-num"><span id="wkg">—</span><span class="unit">W/kg · FTP</span></div>
            <div class="result-lbl" id="category-lbl">Rider category</div>
          </div>

          <div class="callouts">
            <div class="callout">
              <div class="callout-num"><span id="ftp-out">—</span><span class="callout-u">W</span></div>
              <div class="callout-lbl mono">FTP</div>
            </div>
            <div class="callout">
              <div class="callout-num"><span id="w-out">—</span><span class="callout-u">kg</span></div>
              <div class="callout-lbl mono">Weight</div>
            </div>
            <div class="callout">
              <div class="callout-num"><span id="next">—</span><span class="callout-u">W/kg</span></div>
              <div class="callout-lbl mono">To reach next tier</div>
            </div>
          </div>

          <!-- W/kg category band chart -->
          <div class="chart-wrap">
            <div class="chart-title mono">Your W/kg vs category bands</div>
            <svg id="chart" viewBox="0 0 700 180" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg"></svg>
          </div>
        </div>
      </div>

      <details class="notes">
        <summary>Formula & limits</summary>
        <p><strong>W/kg</strong> = FTP (watts) ÷ Body weight (kg).</p>
        <p>FTP-based rider categories (Coggan):</p>
        <pre>                      Male W/kg    Female W/kg
World class           5.6+         5.0+
Exceptional           5.05–5.59    4.50–4.99
Excellent             4.55–5.04    4.05–4.49
Very Good             4.05–4.54    3.60–4.04
Good                  3.55–4.04    3.15–3.59
Moderate              3.05–3.54    2.70–3.14
Fair                  2.55–3.04    2.30–2.69
Untrained             &lt; 2.55       &lt; 2.30</pre>
        <p class="muted">W/kg matters most when gravity does — on climbs and in sustained efforts. For flat TTs and crits, absolute watts (and CdA) often matter more than W/kg.</p>
      </details>
    </div>
  </section>
</Base>

<script>
  const $ = (s) => document.querySelector(s);
  const ftpEl=$('#ftp'), wEl=$('#weight'), chart=$('#chart');

  // Category bands: [lower, label]
  const bandsMale = [
    { lo: 0.00, label: 'Untrained' },
    { lo: 2.55, label: 'Fair' },
    { lo: 3.05, label: 'Moderate' },
    { lo: 3.55, label: 'Good' },
    { lo: 4.05, label: 'Very Good' },
    { lo: 4.55, label: 'Excellent' },
    { lo: 5.05, label: 'Exceptional' },
    { lo: 5.60, label: 'World Class' },
  ];
  const bandsFemale = [
    { lo: 0.00, label: 'Untrained' },
    { lo: 2.30, label: 'Fair' },
    { lo: 2.70, label: 'Moderate' },
    { lo: 3.15, label: 'Good' },
    { lo: 3.60, label: 'Very Good' },
    { lo: 4.05, label: 'Excellent' },
    { lo: 4.50, label: 'Exceptional' },
    { lo: 5.00, label: 'World Class' },
  ];
  // Colors progressing from cool to hot
  const bandColors = ['#3a3a3a', '#4a5e7a', '#4a7a72', '#5f9d6e', '#a9c75a', '#d4a64d', '#e0703a', '#d0413c'];

  function categorize(wkg, bands) {
    let i = 0;
    for (let k = bands.length - 1; k >= 0; k--) {
      if (wkg >= bands[k].lo) { i = k; break; }
    }
    return { i, label: bands[i].label, nextLo: bands[i+1]?.lo ?? null };
  }

  function getSex() { return document.querySelector('input[name="sex"]:checked').value; }

  function calc() {
    const ftp = +ftpEl.value, w = +wEl.value;
    if (!ftp || !w) return;

    const wkg = ftp / w;
    const bands = getSex() === 'male' ? bandsMale : bandsFemale;
    const { i, label, nextLo } = categorize(wkg, bands);

    document.getElementById('wkg').textContent = wkg.toFixed(2);
    document.getElementById('category-lbl').textContent = label;
    document.getElementById('ftp-out').textContent = ftp;
    document.getElementById('w-out').textContent = w;
    document.getElementById('next').textContent = nextLo ? `+${(nextLo - wkg).toFixed(2)}` : '—';

    drawChart(wkg, bands, i);
  }

  function drawChart(wkg, bands, currentIdx) {
    const W=700, H=180, padX=20, barY=44, barH=40;
    const usableW = W - padX*2;
    const xMax = 7; // chart goes to 7 W/kg
    const xScale = (v) => padX + (v/xMax) * usableW;

    let segs = '';
    let labels = '';

    for (let k = 0; k < bands.length; k++) {
      const lo = bands[k].lo;
      const hi = bands[k+1]?.lo ?? xMax;
      const x1 = xScale(lo), x2 = xScale(hi);
      const w = x2 - x1;
      const isCurrent = k === currentIdx;
      segs += `<rect x="${x1}" y="${barY}" width="${w}" height="${barH}" fill="${bandColors[k]}" fill-opacity="${isCurrent ? 1 : 0.45}"/>`;
      // band label
      labels += `<text x="${x1 + w/2}" y="${barY + barH + 18}" fill="${isCurrent ? '#fff' : 'rgba(255,255,255,0.55)'}" font-family="JetBrains Mono, monospace" font-size="9" text-anchor="middle" font-weight="${isCurrent ? 600 : 400}">${bands[k].label}</text>`;
    }

    // axis labels
    let ticks = '';
    for (let v = 1; v <= xMax; v++) {
      const x = xScale(v);
      ticks += `
        <line x1="${x}" x2="${x}" y1="${barY - 4}" y2="${barY}" stroke="rgba(255,255,255,0.25)"/>
        <text x="${x}" y="${barY - 8}" fill="rgba(255,255,255,0.55)" font-family="JetBrains Mono, monospace" font-size="9" text-anchor="middle">${v}</text>
      `;
    }

    // Your W/kg marker
    const markerX = xScale(Math.min(wkg, xMax));
    const marker = `
      <line x1="${markerX}" x2="${markerX}" y1="${barY - 14}" y2="${barY + barH + 6}" stroke="#fff" stroke-width="2"/>
      <circle cx="${markerX}" cy="${barY + barH/2}" r="6" fill="#fff" stroke="var(--ink)" stroke-width="2"/>
      <text x="${markerX}" y="${barY - 20}" fill="#fff" font-family="Bricolage Grotesque, sans-serif" font-weight="600" font-size="12" text-anchor="middle">${wkg.toFixed(2)}</text>
    `;

    chart.innerHTML = segs + labels + ticks + marker;
  }

  document.querySelectorAll('.seg-group').forEach((group) => {
    group.addEventListener('change', () => {
      group.querySelectorAll('.seg').forEach((s) => s.classList.remove('active'));
      group.querySelector('input:checked').closest('.seg').classList.add('active');
      calc();
    });
  });
  [ftpEl, wEl].forEach((el) => el.addEventListener('input', calc));
  calc();
</script>

<style>
  .result-block { background: var(--ink); color: #fff; padding: var(--s-6); }
  .result-headline {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: var(--s-4); flex-wrap: wrap; margin-bottom: var(--s-5);
  }
  .result-headline .unit { font-size: 0.9rem; font-family: var(--font-mono); color: var(--muted-2); margin-left: var(--s-3); }
  .result-headline .result-lbl {
    font-family: var(--font-display); font-weight: 600; font-size: 1.4rem;
    color: #fff; letter-spacing: -0.02em; text-transform: none;
  }

  .callouts {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: var(--s-3); margin-bottom: var(--s-5);
    padding-bottom: var(--s-5); border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  @media (max-width: 560px) { .callouts { grid-template-columns: 1fr; } }
  .callout-num { font-family: var(--font-display); font-weight: 600; font-size: 1.5rem; letter-spacing: -0.02em; line-height: 1; }
  .callout-u { font-size: 0.78rem; font-family: var(--font-mono); color: var(--muted-2); margin-left: 4px; }
  .callout-lbl { color: rgba(255,255,255,0.55); margin-top: 6px; letter-spacing: 0.1em; text-transform: uppercase; font-size: 0.7rem; }

  .chart-wrap { background: rgba(255,255,255,0.03); border-radius: var(--radius); padding: var(--s-3) var(--s-4); }
  .chart-title { color: rgba(255,255,255,0.55); margin-bottom: var(--s-2); letter-spacing: 0.1em; text-transform: uppercase; font-size: 0.7rem; }
  .chart-wrap svg { display: block; width: 100%; height: auto; }
</style>
