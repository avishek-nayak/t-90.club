---
import Base from '../../layouts/Base.astro';
---
<Base title="VDOT training paces — t90.club" description="Daniels' training paces from a recent race time.">
  <section class="calc-page-head">
    <div class="container-narrow">
      <a href="/calculators" class="calc-back">← All calculators</a>
      <div class="eyebrow">Running performance</div>
      <h1>VDOT training paces</h1>
      <p class="calc-lede">Plug in a recent race time. Get Jack Daniels' Easy, Marathon, Threshold, Interval, and Repetition training paces — the foundation of his training system.</p>
    </div>
  </section>

  <section class="section-tight">
    <div class="container-narrow">
      <div class="calc-card">
        <div class="calc-form">
          <div class="row cols-2">
            <label class="field">
              <span class="field-row">Race distance</span>
              <select id="dist">
                <option value="1.609">1 mile</option>
                <option value="3">3 km</option>
                <option value="5" selected>5 km</option>
                <option value="10">10 km</option>
                <option value="15">15 km</option>
                <option value="21.0975">Half marathon</option>
                <option value="42.195">Marathon</option>
              </select>
            </label>
            <label class="field">
              <span class="field-row">Race time <em>mm:ss</em></span>
              <input id="time" type="text" inputmode="numeric" placeholder="22:30" value="22:30"/>
            </label>
          </div>
        </div>

        <div class="result-block">
          <div class="result-headline">
            <div class="result-num"><span id="vdot">—</span><span class="unit">VDOT</span></div>
            <div class="result-lbl">Equivalent VO₂ max performance</div>
          </div>

          <!-- Pace table -->
          <div class="zones">
            <div class="z header">
              <span class="z-name">Zone</span>
              <span class="z-desc">Purpose</span>
              <span class="z-val">Pace</span>
            </div>
            <div class="z" data-row="E"><span class="z-name">E · Easy</span><span class="z-desc">Recovery, base mileage</span><span class="z-val" id="p-E">—</span></div>
            <div class="z" data-row="M"><span class="z-name">M · Marathon</span><span class="z-desc">Marathon-pace work</span><span class="z-val" id="p-M">—</span></div>
            <div class="z" data-row="T"><span class="z-name">T · Threshold</span><span class="z-desc">Tempo, lactate threshold</span><span class="z-val" id="p-T">—</span></div>
            <div class="z" data-row="I"><span class="z-name">I · Interval</span><span class="z-desc">VO₂ max work, 3–5 min reps</span><span class="z-val" id="p-I">—</span></div>
            <div class="z" data-row="R"><span class="z-name">R · Repetition</span><span class="z-desc">Speed, form, anaerobic</span><span class="z-val" id="p-R">—</span></div>
          </div>

          <!-- Horizontal pace ladder -->
          <div class="chart-wrap">
            <div class="chart-title mono">Pace ladder (slow → fast)</div>
            <svg id="chart" viewBox="0 0 700 220" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg"></svg>
          </div>
        </div>
      </div>

      <details class="notes">
        <summary>Formula & limits</summary>
        <p><strong>VDOT</strong> — Jack Daniels' equivalent VO₂max score from race performance:</p>
        <pre>VO₂  = −4.6 + 0.182258·v + 0.000104·v²    (v in m/min)
%max = 0.8 + 0.1894393·e^(−0.012778·t)
            + 0.2989558·e^(−0.1932605·t)   (t in min)
VDOT = VO₂ / %max</pre>
        <p>Training paces are derived from fixed %VDOT bands: Easy 70%, Marathon 84%, Threshold 88%, Interval 97%, Repetition 105%.</p>
        <p class="muted">VDOT is a performance score, not your actual VO₂max — it ranks you by what you've raced. Use it for prescribing training paces, not for medical claims.</p>
      </details>
    </div>
  </section>
</Base>

<script>
  const $ = (s) => document.querySelector(s);
  const distEl=$('#dist'), timeEl=$('#time'), chart=$('#chart');

  function parseTime(str) {
    if (!str) return null;
    const parts = str.split(':').map(s => +s.trim());
    if (parts.some(isNaN)) return null;
    if (parts.length === 3) return parts[0]*3600 + parts[1]*60 + parts[2];
    if (parts.length === 2) return parts[0]*60 + parts[1];
    if (parts.length === 1) return parts[0]*60;
    return null;
  }
  function fmtPace(secPerKm) {
    if (!secPerKm || !isFinite(secPerKm)) return '—';
    const m=Math.floor(secPerKm/60), s=Math.round(secPerKm%60);
    return `${m}:${String(s).padStart(2,'0')}/km`;
  }

  // Daniels' VDOT math
  function vo2FromVelocity(v) { return -4.6 + 0.182258*v + 0.000104*v*v; }
  function pctMax(tMin) {
    return 0.8 + 0.1894393*Math.exp(-0.012778*tMin) + 0.2989558*Math.exp(-0.1932605*tMin);
  }
  // Solve quadratic for velocity given target VO2: 0.000104 v² + 0.182258 v - (4.6 + VO2) = 0
  function velocityFromVo2(vo2) {
    const a=0.000104, b=0.182258, c=-(4.6 + vo2);
    return (-b + Math.sqrt(b*b - 4*a*c)) / (2*a); // m/min
  }

  // Pace zone %VDOT multipliers (Daniels' standard)
  const zones = [
    { id: 'E', pct: 0.70 },
    { id: 'M', pct: 0.84 },
    { id: 'T', pct: 0.88 },
    { id: 'I', pct: 0.97 },
    { id: 'R', pct: 1.05 },
  ];

  function calc() {
    const tSec = parseTime(timeEl.value);
    const dKm = +distEl.value;
    if (!tSec || !dKm) return;

    const vMpm = (dKm * 1000) / (tSec / 60); // m/min
    const vo2 = vo2FromVelocity(vMpm);
    const pct = pctMax(tSec / 60);
    const vdot = vo2 / pct;

    document.getElementById('vdot').textContent = vdot.toFixed(1);

    // For each zone, find target VO2 = vdot × pct, solve for velocity, convert to pace
    const paces = zones.map((z) => {
      const targetVo2 = vdot * z.pct;
      const v = velocityFromVo2(targetVo2);   // m/min
      const secPerKm = 60 / (v/1000);          // sec/km
      return { ...z, secPerKm };
    });

    paces.forEach((p) => {
      document.getElementById(`p-${p.id}`).textContent = fmtPace(p.secPerKm);
    });

    drawChart(paces);
  }

  function drawChart(paces) {
    const W=700, H=220, padL=44, padR=44, padT=24, padB=36;
    const plotW = W - padL - padR;

    // X axis: pace in sec/km. Slow on LEFT, fast on RIGHT.
    const slow = Math.max(...paces.map(p => p.secPerKm));
    const fast = Math.min(...paces.map(p => p.secPerKm));
    const range = slow - fast;
    const xMax = slow + range * 0.10;
    const xMin = fast - range * 0.10;
    const xScale = (s) => padL + ((xMax - s) / (xMax - xMin)) * plotW; // inverted so fast on right

    const rowH = 30;
    const colors = ['#888', '#aaa', 'var(--accent)', '#ff8a5c', '#fff'];

    let rows = '';
    paces.forEach((p, i) => {
      const y = padT + i*rowH + 6;
      const x = xScale(p.secPerKm);
      rows += `
        <text x="${padL - 10}" y="${y+rowH/2+3}" fill="rgba(255,255,255,0.85)" font-family="Bricolage Grotesque, sans-serif" font-weight="600" font-size="12" text-anchor="end">${p.id}</text>
        <line x1="${padL}" x2="${padL+plotW}" y1="${y+rowH/2}" y2="${y+rowH/2}" stroke="rgba(255,255,255,0.06)"/>
        <circle cx="${x}" cy="${y+rowH/2}" r="6" fill="${colors[i]}"/>
        <text x="${x}" y="${y+rowH/2-12}" fill="rgba(255,255,255,0.85)" font-family="JetBrains Mono, monospace" font-size="10" text-anchor="middle">${fmtPace(p.secPerKm)}</text>
      `;
    });

    // x-axis labels (slow/fast)
    const xAxis = `
      <text x="${padL}" y="${H - padB + 18}" fill="rgba(255,255,255,0.5)" font-family="JetBrains Mono, monospace" font-size="10" text-anchor="start">SLOWER</text>
      <text x="${padL+plotW}" y="${H - padB + 18}" fill="rgba(255,255,255,0.5)" font-family="JetBrains Mono, monospace" font-size="10" text-anchor="end">FASTER</text>
      <line x1="${padL}" x2="${padL+plotW}" y1="${H - padB + 4}" y2="${H - padB + 4}" stroke="rgba(255,255,255,0.15)"/>
    `;

    chart.innerHTML = rows + xAxis;
  }

  [distEl, timeEl].forEach((el) => el.addEventListener('input', calc));
  distEl.addEventListener('change', calc);
  calc();
</script>

<style>
  .result-block { background: var(--ink); color: #fff; padding: var(--s-6); }
  .result-headline {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: var(--s-4); flex-wrap: wrap; margin-bottom: var(--s-5);
  }
  .result-headline .unit { font-size: 0.9rem; font-family: var(--font-mono); color: var(--muted-2); margin-left: var(--s-3); }

  .zones { margin-bottom: var(--s-5); }
  .zones .z { grid-template-columns: 130px 1fr 110px; }
  .zones .z.header {
    background: rgba(255,255,255,0.04);
  }
  .zones .z.header .z-name,
  .zones .z.header .z-desc,
  .zones .z.header .z-val {
    font-family: var(--font-mono); font-size: 0.7rem;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: rgba(255,255,255,0.55); font-weight: 400;
  }
  .zones .z-val { text-align: right; }

  .chart-wrap { background: rgba(255,255,255,0.03); border-radius: var(--radius); padding: var(--s-3) var(--s-4); }
  .chart-title { color: rgba(255,255,255,0.55); margin-bottom: var(--s-2); letter-spacing: 0.1em; text-transform: uppercase; font-size: 0.7rem; }
  .chart-wrap svg { display: block; width: 100%; height: auto; }
</style>
