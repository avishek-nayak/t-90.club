---
import Base from '../../layouts/Base.astro';
import { categories, totalCount } from '../../lib/catalog.js';
---
<Base title="Calculators — t90.club" description="All endurance calculators, organized by category.">
  <section class="page-head">
    <div class="container">
      <div class="eyebrow">Calculators</div>
      <h1>{totalCount}+ tools.<br/>Pick one. Get an answer.</h1>
      <p class="lede muted">Inputs stay in your browser. No accounts. No tracking.</p>

      <!-- Live filter -->
      <div class="filter-row">
        <input id="q" class="filter-input" type="search" placeholder="Filter calculators — try ‘pace’, ‘FTP’, ‘carbs’…" aria-label="Filter calculators" />
        <span class="mono muted" id="count">{totalCount} tools</span>
      </div>

      <!-- Category jumplinks -->
      <nav class="jump" aria-label="Jump to category">
        {categories.map((c) => (
          <a href={`#${c.id}`} class="jump-link">
            <span>{c.name}</span>
            <span class="mono muted">{c.calculators.length}</span>
          </a>
        ))}
      </nav>
    </div>
  </section>

  {categories.map((c) => (
    <section class="cat-section" id={c.id}>
      <div class="container">
        <header class="cat-head">
          <div>
            <h2>{c.name}</h2>
            <p class="muted">{c.blurb}</p>
          </div>
          <span class="mono muted">{c.calculators.length} tools</span>
        </header>

        <ul class="calc-grid" role="list">
          {c.calculators.map((calc) => (
            <li class={`calc-card ${calc.status}`} data-name={calc.name.toLowerCase()} data-desc={calc.desc.toLowerCase()}>
              <a href={`/calculators/${calc.slug}`} class={`calc-link ${calc.status === 'soon' ? 'is-soon' : ''}`}>
                <div class="calc-top">
                  <h3>{calc.name}</h3>
                  <span class={`status ${calc.status}`}>{calc.status === 'live' ? 'Live' : 'Soon'}</span>
                </div>
                <p>{calc.desc}</p>
                <span class="calc-arrow">{calc.status === 'live' ? 'Open →' : 'Preview →'}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </section>
  ))}
</Base>

<script>
  // Lightweight client-side filter — no framework needed.
  const q = document.getElementById('q');
  const count = document.getElementById('count');
  const cards = Array.from(document.querySelectorAll('.calc-card'));
  const total = cards.length;
  q?.addEventListener('input', () => {
    const term = q.value.trim().toLowerCase();
    let shown = 0;
    cards.forEach((card) => {
      const hay = (card.dataset.name || '') + ' ' + (card.dataset.desc || '');
      const match = !term || hay.includes(term);
      card.style.display = match ? '' : 'none';
      if (match) shown++;
    });
    if (count) count.textContent = term ? `${shown} of ${total} tools` : `${total} tools`;
  });
</script>

<style>
  .page-head { padding: var(--s-9) 0 var(--s-7); border-bottom: 1px solid var(--line); }
  .page-head h1 { margin-top: var(--s-3); }
  .lede { font-size: 1.1rem; max-width: 640px; margin-top: var(--s-4); }

  .filter-row {
    display: flex; align-items: center; gap: var(--s-4);
    margin-top: var(--s-6); max-width: 640px;
  }
  .filter-input {
    flex: 1; padding: 12px 14px;
    background: var(--canvas-2); border: 1px solid var(--line);
    border-radius: var(--radius); font: inherit;
    color: var(--ink);
    transition: border-color 150ms ease;
  }
  .filter-input:focus { outline: none; border-color: var(--ink); }

  .jump {
    display: flex; flex-wrap: wrap; gap: var(--s-2);
    margin-top: var(--s-6);
  }
  .jump-link {
    display: inline-flex; align-items: center; gap: var(--s-2);
    padding: 7px 12px; border: 1px solid var(--line);
    border-radius: 999px; background: var(--canvas-2);
    font-size: 0.86rem;
  }
  .jump-link:hover { border-color: var(--ink); color: var(--ink); }

  .cat-section { padding: var(--s-8) 0 var(--s-7); border-bottom: 1px solid var(--line); }
  .cat-section:last-of-type { border-bottom: 0; }
  .cat-head {
    display: flex; justify-content: space-between; align-items: flex-end;
    margin-bottom: var(--s-6); gap: var(--s-5);
  }
  .cat-head h2 { margin-top: var(--s-2); }
  .cat-head p { margin: var(--s-2) 0 0; max-width: 540px; }

  .calc-grid {
    list-style: none; padding: 0; margin: 0;
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border-top: 1px solid var(--line);
    border-left: 1px solid var(--line);
  }
  @media (max-width: 920px) { .calc-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .calc-grid { grid-template-columns: 1fr; } }

  .calc-card { background: var(--canvas-2); }
  .calc-link {
    display: flex; flex-direction: column; justify-content: space-between;
    height: 100%;
    padding: var(--s-5);
    border-right: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    transition: background 150ms ease;
    min-height: 160px;
  }
  .calc-link:hover { background: var(--canvas); color: var(--ink); }
  .calc-link.is-soon { opacity: 0.85; }
  .calc-link.is-soon:hover { opacity: 1; }

  .calc-top {
    display: flex; justify-content: space-between; align-items: flex-start;
    gap: var(--s-3); margin-bottom: var(--s-3);
  }
  .calc-card h3 { font-size: 1rem; line-height: 1.25; }
  .calc-card p { color: var(--muted); margin: 0 0 var(--s-4); font-size: 0.92rem; }
  .calc-arrow { font-size: 0.85rem; font-weight: 500; color: var(--ink); }
  .calc-link:hover .calc-arrow { color: var(--accent); }
  .calc-link.is-soon .calc-arrow { color: var(--muted); }

  .status {
    font-family: var(--font-mono);
    font-size: 0.65rem; letter-spacing: 0.08em;
    padding: 3px 7px; border-radius: 4px;
    text-transform: uppercase;
    border: 1px solid var(--line);
    color: var(--muted);
    background: var(--canvas);
    white-space: nowrap;
  }
  .status.live { color: var(--good); border-color: color-mix(in oklab, var(--good) 30%, var(--line)); background: color-mix(in oklab, var(--good) 6%, var(--canvas-2)); }
  .status.soon { color: var(--muted); }
</style>
